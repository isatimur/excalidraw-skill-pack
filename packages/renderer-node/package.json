{
  "name": "@excalidraw-skill-pack/render",
  "version": "0.3.1",
  "description": "Render Excalidraw JSON to PNG. Node binding for excalidraw-skill-pack.",
  "license": "MIT",
  "author": "Timur Isachenko",
  "homepage": "https://excalidraw-skill-pack.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isatimur/excalidraw-skill-pack.git",
    "directory": "packages/renderer-node"
  },
  "bugs": {
    "url": "https://github.com/isatimur/excalidraw-skill-pack/issues"
  },
  "keywords": [
    "excalidraw",
    "render",
    "png",
    "playwright",
    "diagrams",
    "cli",
    "headless"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "@excalidraw-skill-pack/render": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/render_template.html"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/render_template.html dist/render_template.html",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@excalidraw-skill-pack/core": "workspace:*",
    "commander": "^12.0.0",
    "playwright-core": "^1.45.0",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

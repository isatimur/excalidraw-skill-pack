{
  "name": "@excalidraw-skill-pack/core",
  "version": "0.2.1",
  "description": "Core methodology, schemas, and bundled default-sketchy theme for excalidraw-skill-pack.",
  "license": "MIT",
  "author": "Timur Isachenko",
  "homepage": "https://excalidraw-skill-pack.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isatimur/excalidraw-skill-pack.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/isatimur/excalidraw-skill-pack/issues"
  },
  "keywords": [
    "excalidraw",
    "diagrams",
    "ai-agent",
    "claude",
    "mcp",
    "skill",
    "methodology",
    "visualization",
    "diagram-as-code"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./skill": "./SKILL.md",
    "./theme-schema": "./theme.schema.json",
    "./themes/default-sketchy": "./themes/default-sketchy/theme.json"
  },
  "files": [
    "dist",
    "SKILL.md",
    "element-templates.md",
    "json-schema.md",
    "theme.schema.json",
    "themes/default-sketchy"
  ],
  "bin": {
    "validate-theme": "./dist/validate-theme.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "vitest": "^1.5.0"
  }
}

{
  "name": "create-excalidraw-theme",
  "version": "0.1.0",
  "description": "Scaffold a new excalidraw-skill-pack theme package (npm + PyPI mirror).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "create-excalidraw-theme": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/template"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -R src/template dist/template",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

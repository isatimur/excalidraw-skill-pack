{
  "name": "@excalidraw-skill-pack/install",
  "version": "0.1.3",
  "description": "One-command installer for excalidraw-skill-pack adapters.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "excalidraw-skill-pack-install": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/adapters && cp -R ../../adapters/. dist/adapters/",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@excalidraw-skill-pack/core": "^0.1.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

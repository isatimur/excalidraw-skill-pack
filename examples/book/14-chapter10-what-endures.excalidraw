    {
      "type": "text", "id": "pl_se", "x": 94, "y": 302, "width": 572, "height": 14,
      "text": "SAMPLE  —  THE LAST FEW YEARS OF CHURN", "originalText": "SAMPLE  —  THE LAST FEW YEARS OF CHURN",

    {
      "type": "text", "id": "pl_code", "x": 112, "y": 344, "width": 540, "height": 150,
      "text": "2023:  prompt engineering, plugins\n2024:  RAG stacks, \"the year of evals\"\n2025:  MCP, subagents, \"the IDE dies\"\n2026:  ... the next framework\n\nleaderboard scores -> stale in weeks", "originalText": "2023:  prompt engineering, plugins\n2024:  RAG stacks, \"the year of evals\"\n2025:  MCP, subagents, \"the IDE dies\"\n2026:  ... the next framework\n\nleaderboard scores -> stale in weeks",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#fcd34d", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 1400016, "version": 1, "versionNonce": 1400016, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.6
    },
    {
      "type": "text", "id": "pl_take", "x": 94, "y": 530, "width": 572, "height": 18,
      "text": "Chasing only the transient layer is a treadmill.", "originalText": "Chasing only the transient layer is a treadmill.",

    {
      "type": "text", "id": "pr_se", "x": 834, "y": 302, "width": 572, "height": 14,
      "text": "SAMPLE  —  THE PRINCIPLES THAT PERSIST", "originalText": "SAMPLE  —  THE PRINCIPLES THAT PERSIST",

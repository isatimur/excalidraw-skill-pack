    {
      "type": "text", "id": "pr_code", "x": 852, "y": 338, "width": 540, "height": 168,
      "text": "constrained delegation      (ch 1, 3)\nexplicit context             (ch 5)\neval loops                   (ch 4)\nstateful, durable runtimes   (ch 6)\nidentity & bounded trust     (ch 7)\nhuman judgment               (ch 2, 9)", "originalText": "constrained delegation      (ch 1, 3)\nexplicit context             (ch 5)\neval loops                   (ch 4)\nstateful, durable runtimes   (ch 6)\nidentity & bounded trust     (ch 7)\nhuman judgment               (ch 2, 9)",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 1400026, "version": 1, "versionNonce": 1400026, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
    },
    {
      "type": "text", "id": "pr_take", "x": 834, "y": 530, "width": 572, "height": 18,
      "text": "Build on the durable layer; let tools come and go.", "originalText": "Build on the durable layer; let tools come and go.",

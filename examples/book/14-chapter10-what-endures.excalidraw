    {
      "type": "text", "id": "role", "x": 200, "y": 112, "width": 1100, "height": 20,
      "text": "Close by separating durable principles from temporary tools — an operating model that survives churn.", "originalText": "Close by separating durable principles from temporary tools — an operating model that survives churn.",

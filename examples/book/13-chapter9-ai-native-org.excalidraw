    {
      "type": "text", "id": "pl_code", "x": 112, "y": 338, "width": 540, "height": 168,
      "text": "plan:    + 500 AI seats\norg:     unchanged\nroles:   unchanged\nreview:  same 2 reviewers, 5x the PRs\nresult:  giant queue, no shared context\n         -> \"alignment debt\"", "originalText": "plan:    + 500 AI seats\norg:     unchanged\nroles:   unchanged\nreview:  same 2 reviewers, 5x the PRs\nresult:  giant queue, no shared context\n         -> \"alignment debt\"",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#fca5a5", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 1300016, "version": 1, "versionNonce": 1300016, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5

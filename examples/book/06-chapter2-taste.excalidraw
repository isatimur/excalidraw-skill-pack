    {
      "type": "text", "id": "pl_code", "x": 112, "y": 334, "width": 540, "height": 168,
      "text": "function h(d) {\n  let r = []\n  for (i in d) {\n    try { r.push(d[i].val * 2) }\n    catch (e) {}          // error swallowed\n  }\n  return r                // i leaks global\n}", "originalText": "function h(d) {\n  let r = []\n  for (i in d) {\n    try { r.push(d[i].val * 2) }\n    catch (e) {}          // error swallowed\n  }\n  return r                // i leaks global\n}",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#fca5a5", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 600016, "version": 1, "versionNonce": 600016, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5

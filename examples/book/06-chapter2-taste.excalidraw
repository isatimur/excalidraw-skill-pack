    {
      "type": "text", "id": "pr_code", "x": 852, "y": 334, "width": 540, "height": 168,
      "text": "/* Doubles each sensor reading.\n   Invalid input is a caller error. */\nfunction doubleReadings(\n  readings: Reading[]\n): number[] {\n  return readings.map(r => r.value * 2)\n}\n// + a test that pins the contract", "originalText": "/* Doubles each sensor reading.\n   Invalid input is a caller error. */\nfunction doubleReadings(\n  readings: Reading[]\n): number[] {\n  return readings.map(r => r.value * 2)\n}\n// + a test that pins the contract",

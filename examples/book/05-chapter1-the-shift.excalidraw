    {
      "type": "text", "id": "pr_char", "x": 884, "y": 304, "width": 512, "height": 40,
      "text": "A candidate worker. It plans, acts,\nand adapts; you steer and supervise.", "originalText": "A candidate worker. It plans, acts,\nand adapts; you steer and supervise.",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#0f2540", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 500024, "version": 1, "versionNonce": 500024, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
    },
    {
      "type": "text", "id": "pr_attr", "x": 884, "y": 358, "width": 512, "height": 96,
      "text": "Interface    more than a chat\nMode         delegated execution\nScope        long-running, high-stakes\nYou hold     judgment, steering, accountability", "originalText": "Interface    more than a chat\nMode         delegated execution\nScope        long-running, high-stakes\nYou hold     judgment, steering, accountability",

    {
      "type": "text", "id": "pl_char", "x": 104, "y": 304, "width": 512, "height": 40,
      "text": "A faster autocomplete. It suggests;\nyou still decide and do the work.", "originalText": "A faster autocomplete. It suggests;\nyou still decide and do the work.",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 500014, "version": 1, "versionNonce": 500014, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
    },
    {
      "type": "text", "id": "pl_attr", "x": 104, "y": 358, "width": 512, "height": 96,
      "text": "Interface    a chat box\nMode         suggestion\nScope        one turn, one snippet\nYou hold     all the work — and the risk", "originalText": "Interface    a chat box\nMode         suggestion\nScope        one turn, one snippet\nYou hold     all the work — and the risk",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#475569", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 500015, "version": 1, "versionNonce": 500015, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.6
    },

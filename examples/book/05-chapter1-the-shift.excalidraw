    },
    {
      "type": "text", "id": "c2", "x": 146, "y": 814, "width": 586, "height": 40,
      "text": "Chat alone is an inadequate interface for\ncomplex, long-running, or high-stakes work.", "originalText": "Chat alone is an inadequate interface for\ncomplex, long-running, or high-stakes work.",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

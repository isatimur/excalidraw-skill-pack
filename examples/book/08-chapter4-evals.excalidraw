    {
      "type": "text", "id": "pr_code", "x": 852, "y": 338, "width": 540, "height": 160,
      "text": "eval_case:\n  input:  \"refund a duplicate charge\"\n  expect: issues_refund AND logs_reason\n  judge:  llm_rubric -> 0.0 .. 1.0\n  gate:   score >= 0.9 to ship\n\nprod traces -> new eval cases -> loop", "originalText": "eval_case:\n  input:  \"refund a duplicate charge\"\n  expect: issues_refund AND logs_reason\n  judge:  llm_rubric -> 0.0 .. 1.0\n  gate:   score >= 0.9 to ship\n\nprod traces -> new eval cases -> loop",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 800026, "version": 1, "versionNonce": 800026, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.6
    },

    {
      "type": "text", "id": "pl_code", "x": 112, "y": 338, "width": 540, "height": 160,
      "text": "$ run benchmark\n  MMLU .......... 88.4%\n  \"looks good in the demo — ship it\"\n\n# how regressions are found:\n  by users, in production", "originalText": "$ run benchmark\n  MMLU .......... 88.4%\n  \"looks good in the demo — ship it\"\n\n# how regressions are found:\n  by users, in production",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

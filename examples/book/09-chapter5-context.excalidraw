    {
      "type": "text", "id": "pl_c", "x": 94, "y": 246, "width": 572, "height": 40,
      "text": "Dump the whole doc set in.\nExpose every tool, just in case.", "originalText": "Dump the whole doc set in.\nExpose every tool, just in case.",

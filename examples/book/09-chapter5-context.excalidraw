    {
      "type": "text", "id": "pl_se", "x": 94, "y": 302, "width": 572, "height": 14,
      "text": "SAMPLE  —  WHAT GOES INTO THE MODEL", "originalText": "SAMPLE  —  WHAT GOES INTO THE MODEL",

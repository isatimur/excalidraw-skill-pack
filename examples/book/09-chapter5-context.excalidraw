    },
    {
      "type": "text", "id": "pr_se", "x": 834, "y": 302, "width": 572, "height": 14,
      "text": "SAMPLE  —  CONTEXT, ASSEMBLED BY LAYER", "originalText": "SAMPLE  —  CONTEXT, ASSEMBLED BY LAYER",

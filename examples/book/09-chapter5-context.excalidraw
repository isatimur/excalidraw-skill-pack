    {
      "type": "text", "id": "pl_code", "x": 112, "y": 338, "width": 540, "height": 160,
      "text": "prompt = whole_wiki + all_docs\n       + 200 tool definitions\n       + chat_history (untrimmed)\n\n# 180k tokens. the answer is in\n# there ... somewhere.", "originalText": "prompt = whole_wiki + all_docs\n       + 200 tool definitions\n       + chat_history (untrimmed)\n\n# 180k tokens. the answer is in\n# there ... somewhere.",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#fca5a5", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 900016, "version": 1, "versionNonce": 900016, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.6
    },
    {
      "type": "text", "id": "pl_take", "x": 94, "y": 530, "width": 572, "height": 18,
      "text": "Cost  —  context misassembly: confident, fluent, wrong.", "originalText": "Cost  —  context misassembly: confident, fluent, wrong.",

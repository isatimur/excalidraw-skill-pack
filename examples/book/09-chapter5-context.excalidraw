    {
      "type": "text", "id": "pr_code", "x": 852, "y": 338, "width": 540, "height": 160,
      "text": "retrieve(query)  -> top-k chunks   (RAG)\nmemory.recall(user)                (state)\ngraph.neighbors(entity)         (GraphRAG)\ntools = select_by_intent(task)   (not all)\n\nassemble  ->  ~8k focused tokens", "originalText": "retrieve(query)  -> top-k chunks   (RAG)\nmemory.recall(user)                (state)\ngraph.neighbors(entity)         (GraphRAG)\ntools = select_by_intent(task)   (not all)\n\nassemble  ->  ~8k focused tokens",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 900026, "version": 1, "versionNonce": 900026, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.6
    },
    {
      "type": "text", "id": "pr_take", "x": 834, "y": 530, "width": 572, "height": 18,
      "text": "Payoff  —  the model reasons over the right context.", "originalText": "Payoff  —  the model reasons over the right context.",

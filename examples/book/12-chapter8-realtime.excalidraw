      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "rectangle", "id": "pl_card", "x": 94, "y": 320, "width": 572, "height": 196,
      "strokeColor": "#334155", "backgroundColor": "#1e293b", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 1200015, "version": 1, "versionNonce": 1200015, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "roundness": {"type": 3}
    },
    {
      "type": "text", "id": "pl_code", "x": 112, "y": 338, "width": 540, "height": 168,
      "text": "user speaks ..... wait for silence\nSTT (full) ...... 1200 ms\nLLM (full reply)  1800 ms\nTTS (full) ......  900 ms\n----------------------------------\n~3.9 s of silence — then it talks\nover the user's next sentence", "originalText": "user speaks ..... wait for silence\nSTT (full) ...... 1200 ms\nLLM (full reply)  1800 ms\nTTS (full) ......  900 ms\n----------------------------------\n~3.9 s of silence — then it talks\nover the user's next sentence",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#fca5a5", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 1200016, "version": 1, "versionNonce": 1200016, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
    },
    {
      "type": "text", "id": "pl_take", "x": 94, "y": 530, "width": 572, "height": 18,
      "text": "Cost  —  laggy, interrupting, unusable in real time.", "originalText": "Cost  —  laggy, interrupting, unusable in real time.",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

    {
      "type": "text", "id": "pr_c", "x": 834, "y": 246, "width": 572, "height": 40,
      "text": "Budget the latency. Stream everything.\nDetect turns; handle barge-in.", "originalText": "Budget the latency. Stream everything.\nDetect turns; handle barge-in.",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#065f46", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 1200023, "version": 1, "versionNonce": 1200023, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
    },
    {
      "type": "text", "id": "pr_se", "x": 834, "y": 302, "width": 572, "height": 14,
      "text": "SAMPLE  —  A LATENCY BUDGET", "originalText": "SAMPLE  —  A LATENCY BUDGET",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

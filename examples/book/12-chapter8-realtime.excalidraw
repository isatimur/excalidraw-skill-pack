    {
      "type": "text", "id": "pl_t", "x": 94, "y": 206, "width": 572, "height": 28,
      "text": "Text-chat assumptions, out loud", "originalText": "Text-chat assumptions, out loud",
      "fontSize": 21, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

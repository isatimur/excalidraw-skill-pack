    {
      "type": "text", "id": "pl_se", "x": 94, "y": 302, "width": 572, "height": 14,
      "text": "SAMPLE  —  THE LATENCY PATH", "originalText": "SAMPLE  —  THE LATENCY PATH",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

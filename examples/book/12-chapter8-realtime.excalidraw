    {
      "type": "text", "id": "pr_code", "x": 852, "y": 338, "width": 540, "height": 168,
      "text": "latency budget  <  800 ms\n  VAD / turn-detect ....  50 ms\n  streaming STT ........ 150 ms\n  LLM (first token) .... 350 ms\n  streaming TTS ........ 200 ms\nbarge-in: user speaks -> agent yields", "originalText": "latency budget  <  800 ms\n  VAD / turn-detect ....  50 ms\n  streaming STT ........ 150 ms\n  LLM (first token) .... 350 ms\n  streaming TTS ........ 200 ms\nbarge-in: user speaks -> agent yields",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 1200026, "version": 1, "versionNonce": 1200026, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
    },

    {
      "type": "text", "id": "role", "x": 200, "y": 112, "width": 1100, "height": 20,
      "text": "The moment a system can act, trust depends on identity, boundaries, and defensible control.", "originalText": "The moment a system can act, trust depends on identity, boundaries, and defensible control.",

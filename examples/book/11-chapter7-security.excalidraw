      "type": "text", "id": "pl_h", "x": 94, "y": 186, "width": 572, "height": 16,
      "text": "THE NAIVE WAY", "originalText": "THE NAIVE WAY",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

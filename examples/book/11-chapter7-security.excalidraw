    {
      "type": "text", "id": "pl_se", "x": 94, "y": 302, "width": 572, "height": 14,
      "text": "SAMPLE  —  HOW THE AGENT IS RUN", "originalText": "SAMPLE  —  HOW THE AGENT IS RUN",

    {
      "type": "text", "id": "pr_t", "x": 834, "y": 206, "width": 572, "height": 28,
      "text": "Bounded autonomy", "originalText": "Bounded autonomy",
      "fontSize": 21, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

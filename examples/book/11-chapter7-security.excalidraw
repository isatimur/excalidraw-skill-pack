    {
      "type": "text", "id": "pr_code", "x": 852, "y": 344, "width": 540, "height": 150,
      "text": "token = mint(scope=[\"repo:read\"], ttl=15m)\nrun_in_sandbox(task, token)    # isolated\non action.write: require step_up_oauth()\naudit.log(actor, action, resource, ts)\nroot_of_trust: org identity provider", "originalText": "token = mint(scope=[\"repo:read\"], ttl=15m)\nrun_in_sandbox(task, token)    # isolated\non action.write: require step_up_oauth()\naudit.log(actor, action, resource, ts)\nroot_of_trust: org identity provider",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,

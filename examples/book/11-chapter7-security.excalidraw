    {
      "type": "text", "id": "pl_code", "x": 112, "y": 344, "width": 540, "height": 150,
      "text": "agent.run(task, creds = ADMIN_TOKEN)\n# reads any repo, any secret\n# no sandbox, no audit log\n\nmcp_server: bind 0.0.0.0   (no auth)", "originalText": "agent.run(task, creds = ADMIN_TOKEN)\n# reads any repo, any secret\n# no sandbox, no audit log\n\nmcp_server: bind 0.0.0.0   (no auth)",

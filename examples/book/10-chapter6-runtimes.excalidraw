    {
      "type": "text", "id": "pr_code", "x": 852, "y": 338, "width": 540, "height": 160,
      "text": "workflow:\n  step  fetch_data       [checkpoint]\n  step  draft_changes    [checkpoint]\n  gate  human_approval   <- pauses here\n  step  apply_changes    [durable]\n\n# crash? replay from last checkpoint", "originalText": "workflow:\n  step  fetch_data       [checkpoint]\n  step  draft_changes    [checkpoint]\n  gate  human_approval   <- pauses here\n  step  apply_changes    [durable]\n\n# crash? replay from last checkpoint",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 1000026, "version": 1, "versionNonce": 1000026, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
    },
    {
      "type": "text", "id": "pr_take", "x": 834, "y": 530, "width": 572, "height": 18,
      "text": "Payoff  —  long-running work that survives and is governed.", "originalText": "Payoff  —  long-running work that survives and is governed.",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#047857", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,

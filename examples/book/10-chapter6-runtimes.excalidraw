    {
      "type": "text", "id": "pr_c", "x": 834, "y": 246, "width": 572, "height": 40,
      "text": "Checkpoint state. Make steps replayable.\nGate risky actions on a human.", "originalText": "Checkpoint state. Make steps replayable.\nGate risky actions on a human.",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
